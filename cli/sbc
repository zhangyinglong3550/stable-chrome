#!/usr/bin/env python3
"""stable-chrome CLI (sbc)

Talks to local bridge at http://127.0.0.1:19527
"""

from __future__ import annotations

import argparse
import base64
import json
import os
import sys
import urllib.error
import urllib.request
from pathlib import Path
from typing import Any, Dict, Optional

DEFAULT_BRIDGE = os.getenv("STABLE_CHROME_BRIDGE", "http://127.0.0.1:19527")


def http_json(method: str, path: str, body: Optional[dict] = None, timeout: float = 30.0) -> dict:
    url = DEFAULT_BRIDGE.rstrip("/") + path
    data = None
    headers = {"Accept": "application/json"}
    if body is not None:
        data = json.dumps(body, ensure_ascii=False).encode("utf-8")
        headers["Content-Type"] = "application/json"
    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            raw = resp.read().decode("utf-8")
            return json.loads(raw) if raw else {}
    except urllib.error.HTTPError as e:
        raw = e.read().decode("utf-8", errors="replace")
        try:
            payload = json.loads(raw) if raw else {"ok": False, "error": str(e)}
        except Exception:
            payload = {"ok": False, "error": raw or str(e)}
        payload.setdefault("ok", False)
        payload.setdefault("httpStatus", e.code)
        return payload
    except Exception as e:
        return {"ok": False, "error": f"bridge unreachable: {e}", "bridge": DEFAULT_BRIDGE}


def out(data: Any, code: int = 0) -> int:
    if isinstance(data, (dict, list)):
        print(json.dumps(data, ensure_ascii=False, indent=2))
    else:
        print(data)
    return code


def cmd_health(_: argparse.Namespace) -> int:
    r = http_json("GET", "/health", timeout=3)
    return out(r, 0 if r.get("ok") else 1)


def cmd_doctor(_: argparse.Namespace) -> int:
    r = http_json("GET", "/doctor", timeout=3)
    return out(r, 0 if r.get("ok") and (r.get("extension") or {}).get("online") else 1)


def run_cmd(type_: str, params: Optional[dict] = None, timeout_ms: int = 20000) -> dict:
    body = {"type": type_, "params": params or {}, "timeoutMs": timeout_ms}
    # also flatten params for convenience
    if params:
        body.update(params)
    return http_json("POST", "/cmd", body, timeout=timeout_ms / 1000.0 + 5)


def cmd_open_tabs(_: argparse.Namespace) -> int:
    r = run_cmd("openTabs")
    return out(r, 0 if r.get("ok") else 1)


DEFAULT_TASK_TITLE = "Agent Task"


def cmd_claim(args: argparse.Namespace) -> int:
    # title 缺省用 Agent Task；显式 --title 才覆盖
    title = args.title if args.title is not None else DEFAULT_TASK_TITLE
    params: Dict[str, Any] = {"title": title}
    if getattr(args, "focus", False):
        params["focus"] = True
    if getattr(args, "color", None):
        params["color"] = args.color
    if getattr(args, "window", False):
        params["window"] = True
    if args.tab_id:
        params["tabId"] = args.tab_id
        r = run_cmd("claimTab", params)
    else:
        r = run_cmd("claimCurrentTab", params)
    return out(r, 0 if r.get("ok") else 1)


def cmd_start_task(args: argparse.Namespace) -> int:
    # 不传 --title 时：扩展侧保持已有任务名（或默认 Agent Task），避免反复改名
    params: Dict[str, Any] = {}
    if args.title is not None:
        params["title"] = args.title
    if getattr(args, "color", None):
        params["color"] = args.color
    # 默认独立窗口（不 focus）；只有显式 --same-window 才和用户同窗
    if getattr(args, "same_window", False):
        params["window"] = False
    else:
        # --window 是默认；保留 flag 兼容旧脚本显式传入
        params["window"] = True
    r = run_cmd("startTask", params)
    return out(r, 0 if r.get("ok") else 1)


def cmd_end_task(args: argparse.Namespace) -> int:
    r = run_cmd("endTask", {"closeGroup": bool(args.close_group)})
    return out(r, 0 if r.get("ok") else 1)


def cmd_reload_extension(_: argparse.Namespace) -> int:
    """热重载 Chrome 扩展（需扩展已加载含 reloadExtension 的版本；首次需在 chrome://extensions 点一次重新加载）。"""
    r = run_cmd("reloadExtension", {}, timeout_ms=5000)
    return out(r, 0 if r.get("ok") else 1)


def cmd_new_tab(args: argparse.Namespace) -> int:
    # 默认后台开页（不抢焦点）；需要前台时用 --active
    # 同任务默认永远单标签：有 claimed 则导航复用；--force 才强制新建
    active = bool(getattr(args, "active", False))
    params: Dict[str, Any] = {"url": args.url, "active": active}
    if getattr(args, "force", False):
        params["force"] = True
    r = run_cmd("newTab", params)
    return out(r, 0 if r.get("ok") else 1)


def cmd_close_tab(args: argparse.Namespace) -> int:
    params: Dict[str, Any] = {}
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("closeTab", params)
    return out(r, 0 if r.get("ok") else 1)


def cmd_goto(args: argparse.Namespace) -> int:
    params: Dict[str, Any] = {"url": args.url}
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("goto", params, timeout_ms=args.timeout_ms)
    return out(r, 0 if r.get("ok") else 1)


def cmd_click(args: argparse.Namespace) -> int:
    params: Dict[str, Any] = {}
    if args.selector:
        params["selector"] = args.selector
    if args.text:
        params["text"] = args.text
    if args.index is not None:
        params["index"] = args.index
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("click", params)
    return out(r, 0 if r.get("ok") else 1)


def cmd_fill(args: argparse.Namespace) -> int:
    params = {"selector": args.selector, "value": args.value}
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("fill", params)
    return out(r, 0 if r.get("ok") else 1)


def cmd_eval(args: argparse.Namespace) -> int:
    params = {"expression": args.expression}
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("eval", params, timeout_ms=args.timeout_ms)
    return out(r, 0 if r.get("ok") else 1)


def cmd_snapshot(args: argparse.Namespace) -> int:
    params: Dict[str, Any] = {"max": args.max}
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("snapshot", params)
    return out(r, 0 if r.get("ok") else 1)


def cmd_content(args: argparse.Namespace) -> int:
    params: Dict[str, Any] = {}
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("content", params)
    return out(r, 0 if r.get("ok") else 1)


def cmd_wait(args: argparse.Namespace) -> int:
    params: Dict[str, Any] = {"timeoutMs": args.timeout_ms}
    if args.selector:
        params["selector"] = args.selector
    if args.text:
        params["text"] = args.text
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("waitFor", params, timeout_ms=args.timeout_ms + 2000)
    return out(r, 0 if r.get("ok") else 1)


def cmd_screenshot(args: argparse.Namespace) -> int:
    params: Dict[str, Any] = {}
    if args.tab_id:
        params["tabId"] = args.tab_id
    if getattr(args, "focus", False):
        params["focus"] = True
    r = run_cmd("screenshot", params, timeout_ms=30000)
    if not r.get("ok"):
        return out(r, 1)
    result = r.get("result") or {}
    b64 = result.get("base64") or ""
    out_path = Path(args.out).expanduser().resolve()
    out_path.parent.mkdir(parents=True, exist_ok=True)
    out_path.write_bytes(base64.b64decode(b64))
    return out(
        {
            "ok": True,
            "path": str(out_path),
            "tabId": result.get("tabId"),
            "method": result.get("method"),
            "restoredActiveTabId": result.get("restoredActiveTabId"),
        },
        0,
    )


def cmd_reload(args: argparse.Namespace) -> int:
    params: Dict[str, Any] = {"bypassCache": bool(args.bypass_cache)}
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("reload", params)
    return out(r, 0 if r.get("ok") else 1)


def cmd_net_start(args: argparse.Namespace) -> int:
    params: Dict[str, Any] = {}
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("startNetCapture", params, timeout_ms=10000)
    return out(r, 0 if r.get("ok") else 1)


def cmd_net_get(args: argparse.Namespace) -> int:
    params: Dict[str, Any] = {}
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("getNetCapture", params, timeout_ms=10000)
    if not r.get("ok"):
        return out(r, 1)
    requests = (r.get("result") or {}).get("requests", [])
    # 只输出非资源请求（过滤 js/css/img/font/woff）
    if args.filter:
        skip = ('.js', '.css', '.png', '.jpg', '.jpeg', '.gif', '.woff', '.woff2', '.ttf', '.svg', '.ico', '.map')
        requests = [req for req in requests if not any(req['url'].split('?')[0].endswith(s) for s in skip)]
    if args.grep:
        requests = [req for req in requests if args.grep in req['url']]
    for req in requests:
        body_hint = f" | {req['postData'][:80]}" if req.get('postData') else ""
        print(f"{req.get('status','?'):>3}  {req['method']:<6} {req['url']}{body_hint}")
    print(f"\n--- {len(requests)} requests ---")
    return 0


def cmd_net_stop(args: argparse.Namespace) -> int:
    params: Dict[str, Any] = {}
    if args.tab_id:
        params["tabId"] = args.tab_id
    r = run_cmd("stopNetCapture", params, timeout_ms=10000)
    if not r.get("ok"):
        return out(r, 1)
    requests = (r.get("result") or {}).get("requests", [])
    if args.filter:
        skip = ('.js', '.css', '.png', '.jpg', '.jpeg', '.gif', '.woff', '.woff2', '.ttf', '.svg', '.ico', '.map')
        requests = [req for req in requests if not any(req['url'].split('?')[0].endswith(s) for s in skip)]
    if args.grep:
        requests = [req for req in requests if args.grep in req['url']]
    for req in requests:
        body_hint = f" | {req['postData'][:80]}" if req.get('postData') else ""
        print(f"{req.get('status','?'):>3}  {req['method']:<6} {req['url']}{body_hint}")
    print(f"\n--- {len(requests)} requests ---")
    return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="sbc", description="stable-chrome CLI")
    p.add_argument("--bridge", default=DEFAULT_BRIDGE, help="bridge base url")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("health", help="bridge health").set_defaults(func=cmd_health)
    sub.add_parser("doctor", help="full diagnostics").set_defaults(func=cmd_doctor)
    sub.add_parser("open-tabs", help="list open tabs").set_defaults(func=cmd_open_tabs)

    c = sub.add_parser("claim", help="claim tab (current if no --tab-id); silent by default")
    c.add_argument("--tab-id")
    c.add_argument("--title", default=None, help=f"task group title (default: {DEFAULT_TASK_TITLE})")
    c.add_argument(
        "--color",
        choices=["grey", "blue", "red", "yellow", "green", "pink", "purple", "cyan"],
        help="tab group color (new group only; omit for auto)",
    )
    c.add_argument("--focus", action="store_true", help="activate tab and bring Chrome to front (default: off)")
    c.add_argument(
        "--window",
        action="store_true",
        help="move claimed tab into a separate unfocused window (do not steal focus)",
    )
    c.set_defaults(func=cmd_claim)

    s = sub.add_parser("start-task", help="start/reuse task tab group (background, no focus steal)")
    s.add_argument(
        "--title",
        default=None,
        help=f"task group title; omit to keep existing name (new task default: {DEFAULT_TASK_TITLE})",
    )
    s.add_argument(
        "--color",
        choices=["grey", "blue", "red", "yellow", "green", "pink", "purple", "cyan"],
        help="tab group color (new group only; omit for auto)",
    )
    s.add_argument(
        "--window",
        action="store_true",
        default=True,
        help="use a dedicated unfocused Chrome window (default: on)",
    )
    s.add_argument(
        "--same-window",
        action="store_true",
        help="keep agent tabs in the current Chrome window (disables --window)",
    )
    s.set_defaults(func=cmd_start_task)

    e = sub.add_parser("end-task", help="end task")
    e.add_argument("--close-group", action="store_true")
    e.set_defaults(func=cmd_end_task)

    sub.add_parser(
        "reload-extension",
        help="hot-reload the Chrome extension (picks up latest background.js)",
    ).set_defaults(func=cmd_reload_extension)

    n = sub.add_parser(
        "new-tab",
        help="open or navigate task tab (single-tab by default, background)",
    )
    n.add_argument("--url", default="about:blank")
    n.add_argument("--background", action="store_true", help="(default) open without activating")
    n.add_argument("--active", action="store_true", help="activate the new tab (may interrupt user)")
    n.add_argument(
        "--force",
        action="store_true",
        help="force create a second tab (default: always reuse the single claimed tab)",
    )
    n.set_defaults(func=cmd_new_tab)

    ct = sub.add_parser("close-tab", help="close a tab by id (or current claimed tab)")
    ct.add_argument("--tab-id")
    ct.set_defaults(func=cmd_close_tab)

    g = sub.add_parser("goto", help="navigate")
    g.add_argument("url")
    g.add_argument("--tab-id")
    g.add_argument("--timeout-ms", type=int, default=30000)
    g.set_defaults(func=cmd_goto)

    cl = sub.add_parser("click", help="click element")
    cl.add_argument("--selector")
    cl.add_argument("--text")
    cl.add_argument("--index", type=int)
    cl.add_argument("--tab-id")
    cl.set_defaults(func=cmd_click)

    f = sub.add_parser("fill", help="fill input")
    f.add_argument("--selector", required=True)
    f.add_argument("--value", required=True)
    f.add_argument("--tab-id")
    f.set_defaults(func=cmd_fill)

    ev = sub.add_parser("eval", help="eval JS expression")
    ev.add_argument("expression")
    ev.add_argument("--tab-id")
    ev.add_argument("--timeout-ms", type=int, default=20000)
    ev.set_defaults(func=cmd_eval)

    sn = sub.add_parser("snapshot", help="list interactive elements")
    sn.add_argument("--max", type=int, default=80)
    sn.add_argument("--tab-id")
    sn.set_defaults(func=cmd_snapshot)

    co = sub.add_parser("content", help="read page content summary")
    co.add_argument("--tab-id")
    co.set_defaults(func=cmd_content)

    w = sub.add_parser("wait", help="wait for selector or text")
    w.add_argument("--selector")
    w.add_argument("--text")
    w.add_argument("--tab-id")
    w.add_argument("--timeout-ms", type=int, default=15000)
    w.set_defaults(func=cmd_wait)

    sc = sub.add_parser(
        "screenshot",
        help="screenshot tab via CDP (no tab switch); falls back to captureVisibleTab",
    )
    sc.add_argument("--out", default=str(Path.home() / "file/codex/sbc-screenshot.png"))
    sc.add_argument("--tab-id")
    sc.add_argument(
        "--focus",
        action="store_true",
        help="bring Chrome window to front (default: off; not needed for CDP screenshot)",
    )
    sc.set_defaults(func=cmd_screenshot)

    rl = sub.add_parser("reload", help="reload tab")
    rl.add_argument("--tab-id")
    rl.add_argument("--bypass-cache", action="store_true")
    rl.set_defaults(func=cmd_reload)

    ns = sub.add_parser("net-start", help="start CDP network capture on tab")
    ns.add_argument("--tab-id")
    ns.set_defaults(func=cmd_net_start)

    ng = sub.add_parser("net-get", help="read captured requests (keep capturing)")
    ng.add_argument("--tab-id")
    ng.add_argument("--filter", action="store_true", default=True, help="skip static assets")
    ng.add_argument("--grep", default="", help="filter by URL substring")
    ng.set_defaults(func=cmd_net_get)

    nst = sub.add_parser("net-stop", help="stop capture and print all requests")
    nst.add_argument("--tab-id")
    nst.add_argument("--filter", action="store_true", default=True)
    nst.add_argument("--grep", default="", help="filter by URL substring")
    nst.set_defaults(func=cmd_net_stop)

    return p


def main(argv: Optional[list] = None) -> int:
    global DEFAULT_BRIDGE
    parser = build_parser()
    args = parser.parse_args(argv)
    if getattr(args, "bridge", None):
        DEFAULT_BRIDGE = args.bridge
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
